<Page x:Class="Tuhvatshin_glaski_save.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Tuhvatshin_glaski_save"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditPage" FontFamily="Century Gothic">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock FontSize="15" Height="20" Width="150">Наименование</TextBlock>
            <TextBox Text="{Binding Title}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <TextBlock FontSize="15" Height="20" Width="150">Адрес</TextBlock>
            <TextBox Text="{Binding Address}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBlock FontSize="15" Height="20" Width="150">Директор</TextBlock>
            <TextBox Text="{Binding DirectorName}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Grid.RowSpan="2">
            <TextBlock FontSize="15" Width="150" Height="20">Логотип</TextBlock>
            <Image Name="LogoImage">
                <Image.Source>
                    <Binding Path="Logo" TargetNullValue="/res/picture.png"></Binding>
                </Image.Source>
            </Image>
        </StackPanel>
        <Button Name="ChangePicBtn" Click="ChangePicBtn_Click" Grid.Row="5">Изменить</Button>
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="Тип аренды" FontSize="15" Width="150" Height="20"></TextBlock>
            <ComboBox Width="100" Height="30" FontSize="15" Name="ComboType" SelectedIndex="{Binding AgentTypeID}">
                <Label Content=""></Label>
                <Label Content="МФО"></Label>
                <Label Content="ООО"></Label>
                <Label Content="ЗАО"></Label>
                <Label Content="МКК"></Label>
                <Label Content="ОАО"></Label>
                <Label Content="ПАО"></Label>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="Приоритет" FontSize="15" Width="150" Height="20"></TextBlock>
            <TextBox Text="{Binding Priority}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="ИНН" FontSize="15" Width="150" Height="20"></TextBlock>
            <TextBox Text="{Binding INN}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>

        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="КПП" FontSize="15" Width="150" Height="20"></TextBlock>
            <TextBox Text="{Binding KPP}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>

        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="Email" FontSize="15" Width="150" Height="20"></TextBlock>
            <TextBox Text="{Binding Email}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>

        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="Телефон" FontSize="15" Width="150" Height="20"></TextBlock>
            <TextBox Text="{Binding Phone}" FontSize="15" Height="20" Width="250"></TextBox>
        </StackPanel>

        <StackPanel Grid.Row="6" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Name="SaveBtn" Click="SaveBtn_Click"></Button>
        </StackPanel>

        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Удалить" Name="DelBtn" Click="DelBtn_Click"></Button>
        </StackPanel>
    </Grid>
</Page>
